rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is logged in
    function isSignedIn() {
      return request.auth != null;
    }

    // Founder/superadmin allowlist — mirrors the client-side check in
    // App.tsx's getEffectiveTier().
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'correo.solutionsgpa@gmail.com' ||
        request.auth.token.email == 'solutionsgpa@gmail.com' ||
        request.auth.token.email.matches('.*solutionsgpa.*') ||
        request.auth.token.email.matches('^fabiola.*') ||
        request.auth.token.email.matches('.*@autocompt[.]ca$')
      );
    }

    // User profile document rules
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // General collection rules with multi-tenant isolation by ownerId.
    // NOTE: `request.resource` only exists on writes — referencing it inside
    // a combined `allow read, write` rule makes every read (get AND query)
    // evaluate that clause too, which errors out and denies the read. Reads
    // and writes are split below so each only references what's defined for it.
    function isOwnerDoc() {
      return isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
    function isOwnerWrite() {
      return isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }

    match /companies/{companyId} {
      allow read: if isOwnerDoc();
      allow create: if isOwnerWrite();
      allow update, delete: if isOwnerDoc();
    }

    match /expenses/{expenseId} {
      allow read: if isOwnerDoc();
      allow create: if isOwnerWrite();
      allow update, delete: if isOwnerDoc();
    }

    match /properties/{propertyId} {
      allow read: if isOwnerDoc();
      allow create: if isOwnerWrite();
      allow update, delete: if isOwnerDoc();
    }

    match /loyers/{loyerId} {
      allow read: if isOwnerDoc();
      allow create: if isOwnerWrite();
      allow update, delete: if isOwnerDoc();
    }

    match /maintenance_components/{componentId} {
      allow read: if isOwnerDoc();
      allow create: if isOwnerWrite();
      allow update, delete: if isOwnerDoc();
    }

    match /buildings/{buildingId} {
      allow read: if isOwnerDoc();
      allow create: if isOwnerWrite();
      allow update, delete: if isOwnerDoc();
    }

    match /units/{unitId} {
      allow read: if isOwnerDoc();
      allow create: if isOwnerWrite();
      allow update, delete: if isOwnerDoc();
    }

    match /journalEntries/{entryId} {
      allow read: if isOwnerDoc();
      allow create: if isOwnerWrite();
      allow update, delete: if isOwnerDoc();
    }

    match /journalLines/{lineId} {
      allow read: if isOwnerDoc();
      allow create: if isOwnerWrite();
      allow update, delete: if isOwnerDoc();
    }

    // Beta access codes — `get` must work BEFORE the user is authenticated
    // (redemption is checked during signup), so it's public by exact code
    // (doc ID) only. `list` (enumerating every code) is superadmin-only,
    // used by the admin "Codes Beta" tab.
    match /betaCodes/{code} {
      allow get: if true;
      allow list: if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update: if isSignedIn()
        && resource.data.status == 'unused'
        && resource.data.email == request.auth.token.email
        && request.resource.data.status == 'redeemed';
      allow delete: if isSuperAdmin();
    }

    // Default deny — any collection not explicitly matched above is inaccessible.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
