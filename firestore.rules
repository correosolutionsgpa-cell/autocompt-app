rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is logged in
    function isSignedIn() {
      return request.auth != null;
    }

    // Founder/superadmin allowlist — mirrors the client-side check in
    // App.tsx's getEffectiveTier().
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'correo.solutionsgpa@gmail.com' ||
        request.auth.token.email == 'solutionsgpa@gmail.com' ||
        request.auth.token.email.matches('.*solutionsgpa.*') ||
        request.auth.token.email.matches('^fabiola.*') ||
        request.auth.token.email.matches('.*@autocompt[.]ca$')
      );
    }

    // User profile document rules
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin());
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // General collection rules with multi-tenant isolation by ownerId.
    // NOTE: `request.resource` only exists on writes — referencing it inside
    // a combined `allow read, write` rule makes every read (get AND query)
    // evaluate that clause too, which errors out and denies the read. Reads
    // and writes are split below so each only references what's defined for it.
    function isOwnerDoc() {
      return isSignedIn() && resource.data.ownerId == request.auth.uid;
    }
    function isOwnerWrite() {
      return isSignedIn() && request.resource.data.ownerId == request.auth.uid;
    }
    // A business partner added to a company's collaboratorUIDs (via the real
    // invite flow below) — read-only for now on the company doc itself.
    function isCollaboratorDoc() {
      return isSignedIn() && request.auth.uid in resource.data.get('collaboratorUIDs', []);
    }
    // Same idea, for records that belong to a shared company rather than the
    // `companies` doc itself: expenses/invoices/properties/etc. store a
    // `companyId` field equal to the `companies` doc's own id, so this looks
    // that company doc up and checks the requesting user is on its
    // collaboratorUIDs list. Read-only, mirroring isCollaboratorDoc().
    function isCollaboratorOnCompany() {
      return isSignedIn() && resource.data.companyId != null &&
        request.auth.uid in get(/databases/$(database)/documents/companies/$(resource.data.companyId)).data.get('collaboratorUIDs', []);
    }
    // Lets an invited user add themselves to a company's collaboratorUIDs —
    // only allowed when a matching *pending* invite exists (see
    // `companyInvites` below) and the update touches nothing else.
    function isAcceptingOwnInvite(companyId) {
      return isSignedIn() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['collaboratorUIDs']) &&
        request.auth.uid in request.resource.data.collaboratorUIDs &&
        exists(/databases/$(database)/documents/companyInvites/$(companyId + '_invite_' + request.auth.token.email)) &&
        get(/databases/$(database)/documents/companyInvites/$(companyId + '_invite_' + request.auth.token.email)).data.status == 'pending';
    }

    match /companies/{companyId} {
      allow read: if isOwnerDoc() || isCollaboratorDoc();
      allow create: if isOwnerWrite();
      allow update: if isOwnerDoc() || isAcceptingOwnInvite(companyId);
      allow delete: if isOwnerDoc();
    }

    // Real invite flow — an owner invites a partner by email; the invite doc
    // id is deterministic (`{companyDocId}_invite_{email}`) so isAcceptingOwnInvite()
    // above can check its existence without a query. The invited person can
    // only read their own invite and flip it to 'accepted'; only the inviter
    // can create/delete invites.
    match /companyInvites/{inviteId} {
      allow read: if isSignedIn() && (
        resource.data.invitedByUid == request.auth.uid ||
        resource.data.invitedEmail == request.auth.token.email
      );
      allow create: if isSignedIn() && request.resource.data.invitedByUid == request.auth.uid;
      allow update: if isSignedIn() &&
        resource.data.invitedEmail == request.auth.token.email &&
        resource.data.status == 'pending' &&
        request.resource.data.status == 'accepted';
      allow delete: if isSignedIn() && resource.data.invitedByUid == request.auth.uid;
    }

    match /expenses/{expenseId} {
      allow read: if isOwnerDoc() || isCollaboratorOnCompany();
      allow create: if isOwnerWrite();
      allow update, delete: if isOwnerDoc();
    }

    match /invoices/{invoiceId} {
      allow read: if isOwnerDoc() || isCollaboratorOnCompany();
      allow create: if isOwnerWrite();
      allow update, delete: if isOwnerDoc();
    }

    match /docTemplates/{templateId} {
      allow read: if isOwnerDoc() || isCollaboratorOnCompany();
      allow create: if isOwnerWrite();
      allow update, delete: if isOwnerDoc();
    }

    // Per-company Google Drive connection metadata (folder id, connected
    // email — never the OAuth token itself). Doc id is `{ownerId}_company_{id}`,
    // scoped the same way as `companies`, since the app's internal company ids
    // ("1", "2"...) repeat across every account.
    match /companyDriveConfig/{configId} {
      allow read: if isOwnerDoc() || isCollaboratorOnCompany();
      allow create: if isOwnerWrite();
      allow update, delete: if isOwnerDoc();
    }

    match /properties/{propertyId} {
      allow read: if isOwnerDoc() || isCollaboratorOnCompany();
      allow create: if isOwnerWrite();
      allow update, delete: if isOwnerDoc();
    }

    match /loyers/{loyerId} {
      allow read: if isOwnerDoc() || isCollaboratorOnCompany();
      allow create: if isOwnerWrite();
      allow update, delete: if isOwnerDoc();
    }

    match /condoUnits/{unitId} {
      allow read: if isOwnerDoc() || isCollaboratorOnCompany();
      allow create: if isOwnerWrite();
      allow update, delete: if isOwnerDoc();
    }

    match /cotisationPayments/{paymentId} {
      allow read: if isOwnerDoc() || isCollaboratorOnCompany();
      allow create: if isOwnerWrite();
      allow update, delete: if isOwnerDoc();
    }

    match /communityPosts/{postId} {
      allow read: if isOwnerDoc() || isCollaboratorOnCompany();
      allow create: if isOwnerWrite();
      allow update, delete: if isOwnerDoc();
    }

    match /legalDocuments/{docId} {
      allow read: if isOwnerDoc() || isCollaboratorOnCompany();
      allow create: if isOwnerWrite();
      allow update, delete: if isOwnerDoc();
    }

    match /syndicSettings/{configId} {
      allow read: if isOwnerDoc() || isCollaboratorOnCompany();
      allow create: if isOwnerWrite();
      allow update, delete: if isOwnerDoc();
    }

    match /maintenance_components/{componentId} {
      allow read: if isOwnerDoc();
      allow create: if isOwnerWrite();
      allow update, delete: if isOwnerDoc();
    }

    match /buildings/{buildingId} {
      allow read: if isOwnerDoc() || isCollaboratorOnCompany();
      allow create: if isOwnerWrite();
      allow update, delete: if isOwnerDoc();
    }

    match /units/{unitId} {
      allow read: if isOwnerDoc() || isCollaboratorOnCompany();
      allow create: if isOwnerWrite();
      allow update, delete: if isOwnerDoc();
    }

    match /journalEntries/{entryId} {
      allow read: if isOwnerDoc();
      allow create: if isOwnerWrite();
      allow update, delete: if isOwnerDoc();
    }

    match /journalLines/{lineId} {
      allow read: if isOwnerDoc();
      allow create: if isOwnerWrite();
      allow update, delete: if isOwnerDoc();
    }

    // AI usage events — cost-tracking log (one doc per Gemini/Claude call).
    // Any signed-in user can log their own events; only SuperAdmin can read
    // the log (aggregated in the "Usage IA" tab). Events are immutable.
    match /aiUsageEvents/{eventId} {
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow read: if isSuperAdmin();
      allow update, delete: if false;
    }

    // Platform invoices — AutoCompt's own SaaS billing (sequential numbering),
    // and the counter doc backing it. SuperAdmin-only in both directions:
    // only Fabiola issues invoices, so no client ever needs to write these.
    match /platformInvoices/{invoiceId} {
      allow read, create: if isSuperAdmin();
      allow update, delete: if false;
    }
    match /counters/{counterId} {
      allow read, write: if isSuperAdmin();
    }

    // Beta access codes — `get` must work BEFORE the user is authenticated
    // (redemption is checked during signup), so it's public by exact code
    // (doc ID) only. `list` (enumerating every code) is superadmin-only,
    // used by the admin "Codes Beta" tab.
    match /betaCodes/{code} {
      allow get: if true;
      allow list: if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update: if isSignedIn()
        && resource.data.status == 'unused'
        && resource.data.email == request.auth.token.email
        && request.resource.data.status == 'redeemed';
      allow delete: if isSuperAdmin();
    }

    // Default deny — any collection not explicitly matched above is inaccessible.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
