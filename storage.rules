rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Document templates the user uploads (their own .docx with {{champs}}),
    // and the final generated PDFs. Isolated by ownerId folder segment —
    // the path itself encodes the owner, so we just compare it to auth.uid
    // (mirrors the ownerId-field checks already used in firestore.rules).
    match /templates/{ownerId}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == ownerId;
    }

    match /generatedDocs/{ownerId}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == ownerId;
    }

    // DocuLegal PDF import flow — PDFs uploaded by the admin for e-signature.
    // The ownerId segment in the path matches the authenticated user's UID.
    match /docuLegalPdfs/{ownerId}/{fileName} {
      allow read: if true;   // Signed link is public — anyone with the link can read
      allow write: if request.auth != null && request.auth.uid == ownerId;
    }

    // Signed document archive — written by server functions after signature completion.
    match /signedDocuments/{ownerId}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == ownerId;
    }

    // Default deny — anything not explicitly matched above is inaccessible.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
